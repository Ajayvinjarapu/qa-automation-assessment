      "id": "7b04bf3f-c1da-45e3-85b4-d57cf18b31a8",
      "name": "Fetch Top JS Repos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        480,
        260
      ],
      "authentication": "genericCredentialType",
      "genericAuthType": "httpHeaderAuth",
      "credentials": {
        "httpHeaderAuth": {
          "id": "github-auth-cred",
          "name": "GitHub Token Authentication"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.first().json.items || [];\nif (items.length === 0) return [];\n\n// Keep only the top 1 repository for enrichment to prevent API rate limits\nconst topRepo = items[0];\nreturn [{\n  json: {\n    name: topRepo.name,\n    owner: topRepo.owner.login,\n    description: topRepo.description,\n    stars: topRepo.stargazers_count,\n    url: topRepo.html_url\n  }\n}];"
      },
      "id": "d040854d-171b-4f96-bd7c-5ab5915d97f2",
      "name": "Keep Top Repo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        260
      ]
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/{{ $json.owner }}/{{ $json.name }}/languages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "User-Agent",
              "value": "n8n-workflow-qa-assessment"
            }
          ]
        },
        "options": {
          "continueOnFail": true
        }
      },
      "id": "c1fcf8d8-7b98-4ea7-90ff-4e789bb734d8",
      "name": "Fetch Repo Languages",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        920,
        260
      ],
      "authentication": "genericCredentialType",
      "genericAuthType": "httpHeaderAuth",
      "credentials": {
        "httpHeaderAuth": {
          "id": "github-auth-cred",
          "name": "GitHub Token Authentication"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const repoInfo = $('Keep Top Repo').first().json;\nconst languages = $input.first().json;\n\n// Handle API fail gracefully\nif (languages.error) {\n  return [{\n    json: {\n      ...repoInfo,\n      languages: 'Unavailable'\n    }\n  }];\n}\n\n// Format top languages list\nconst langList = Object.keys(languages).slice(0, 3).join(', ');\nreturn [{\n  json: {\n    ...repoInfo,\n    languages: langList || 'None'\n  }\n}];"
      },
      "id": "283f3e1b-b4f5-4ca3-b8e7-817ab3de51ff",
      "name": "Merge Repo and Languages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        260
      ]
    },
    {
      "parameters": {
